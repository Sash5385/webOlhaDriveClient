{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "bookings": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "timeslots": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
    },
    "queue": {
      ".read": "auth != null",
      "$slotKey": {
        "entries": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    },
    "invitations": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null"
      }
    },
    "prices": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).val() == true"
    },
    "admins": {
      ".read": "auth != null",
      ".write": false
    }
  }
}
